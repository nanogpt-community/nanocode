name: Build Zed Extension Release

on:
  push:
    branches:
      - dev
    paths:
      - "packages/opencode/package.json"
  workflow_dispatch:
    inputs:
      version:
        description: "Version override (leave empty to use package.json)"
        required: false
        type: string

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: write

jobs:
  get-version:
    runs-on: ubuntu-latest
    outputs:
      version: ${{ steps.version.outputs.version }}
    steps:
      - uses: actions/checkout@v4
      - id: version
        run: |
          if [ -n "${{ inputs.version }}" ]; then
            echo "version=${{ inputs.version }}" >> $GITHUB_OUTPUT
          else
            VERSION=$(jq -r '.version' packages/opencode/package.json)
            echo "version=$VERSION" >> $GITHUB_OUTPUT
          fi

  build-zed-release:
    needs: get-version
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install zip
        run: |
          sudo apt-get update
          sudo apt-get install -y zip

      - name: Package Zed extension
        run: |
          OUT_DIR="$(pwd)/zed-archives"
          mkdir -p "$OUT_DIR"

          cd packages/extensions
          zip -r "$OUT_DIR/zed-${{ needs.get-version.outputs.version }}.zip" zed

          echo "Zed extension archive:"
          ls -la "$OUT_DIR"

      - name: Upload release assets
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v${{ needs.get-version.outputs.version }}
          files: zed-archives/*
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
